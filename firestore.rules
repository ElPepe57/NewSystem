rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // FUNCIONES HELPER
    // ============================================================
    // Nota: get() al mismo path se cachea dentro de la misma evaluacion.
    // Roles: admin, gerente, vendedor, comprador, almacenero, finanzas, supervisor, invitado

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    // chk5.F4-USERS · helper multi-rol · soporta documentos con roles[] (nuevo)
    // y role singular (legacy). Verifica si user tiene un rol específico.
    function userHasRole(role) {
      let data = getUserData();
      // Prefer roles[] (nuevo) · fallback a role singular (legacy)
      return ('roles' in data && data.roles is list && role in data.roles)
          || ('role' in data && data.role == role);
    }

    // chk5.F4-USERS · check si user tiene CUALQUIERA de los roles dados.
    function userHasAnyRole(rolesPermitidos) {
      let data = getUserData();
      return (
        ('roles' in data && data.roles is list && data.roles.hasAny(rolesPermitidos))
        || ('role' in data && data.role in rolesPermitidos)
      );
    }

    function isActive() {
      return getUserData().activo == true;
    }

    function isAdmin() {
      return request.auth != null && isActive() && userHasRole('admin');
    }

    function isActiveUser() {
      return request.auth != null && isActive();
    }

    // LEGACY · sigue funcionando para reglas existentes que comparan role singular
    // NO usar en reglas nuevas · usar userHasRole / userHasAnyRole
    function hasRole(role) {
      return isActiveUser() && userHasRole(role);
    }

    function hasAnyRole(roles) {
      return isActiveUser() && userHasAnyRole(roles);
    }

    // ============================================================
    // USUARIOS
    // chk5.F4-USERS (2026-05-25) · ampliado para multi-rol + estado + audit
    // ============================================================
    match /users/{userId} {
      // Cualquier autenticado puede leer su propio perfil; admin y gerente leen todos
      allow read: if request.auth != null &&
        (request.auth.uid == userId || hasAnyRole(['admin', 'gerente']));

      // Un usuario puede crear su propio perfil (fallback si Cloud Function no lo creó)
      // SEC-007 FIX: solo puede crear con role='invitado'/'invitado' y NO activo
      // Validación coherente con el nuevo modelo: estado='pendiente_aprobacion' permitido
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.get('role', 'invitado') == 'invitado'
        && request.resource.data.get('activo', false) == false
        && (
          !('estado' in request.resource.data)
          || request.resource.data.estado in ['pendiente_aprobacion', 'invitado_no_registrado']
        );

      // Usuario puede actualizar su perfil EXCEPTO role, roles, permisos, activo,
      // estado, permisosCustom, audit fields (todos esos solo admin).
      // chk5.F4-USERS · ampliada la blacklist con campos nuevos.
      allow update: if request.auth != null && (
        isAdmin() ||
        (request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny([
           'role', 'roles', 'permisos', 'permisosCustom', 'activo', 'estado',
           'origen', 'invitadoPor', 'fechaInvitacion', 'fechaAprobacion',
           'aprobadoPor', 'fechaSuspension', 'suspendidoPor', 'motivoSuspension',
           'fechaArchivado', 'archivadoPor'
         ]))
      );

      allow delete: if isAdmin();
    }

    // ============================================================
    // FLUJO DE VENTAS (admin + vendedor escriben, todos leen)
    // ============================================================
    match /ventas/{docId} {
      allow read: if isActiveUser();
      // Vendedor puede escribir, pero NO puede crear ventas bajo costo (solo admin/gerente)
      allow create: if hasAnyRole(['admin', 'gerente', 'vendedor']) &&
        (!request.resource.data.get('ventaBajoCosto', false) ||
         hasAnyRole(['admin', 'gerente']));
      allow update: if hasAnyRole(['admin', 'gerente', 'vendedor']) &&
        // Si se marca ventaBajoCosto en update, solo admin/gerente
        (!request.resource.data.get('ventaBajoCosto', false) ||
         resource.data.get('ventaBajoCosto', false) == true ||
         hasAnyRole(['admin', 'gerente']));
      allow delete: if hasAnyRole(['admin', 'gerente']);
    }

    match /cotizaciones/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'vendedor']);
    }

    match /entregas/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'vendedor']);
    }

    match /entregas_parciales/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'vendedor']);
    }

    match /requerimientos/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'vendedor', 'comprador']);
    }

    match /clientes/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'vendedor']);
    }

    match /proveedores/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'vendedor', 'comprador']);
    }

    // ============================================================
    // INVENTARIO (almacenero + admin escriben, vendedor tambien para reservas/ventas)
    // ============================================================
    match /productos/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'almacenero', 'comprador']);
    }

    match /unidades/{docId} {
      // Vendedor reserva/vende, almacenero recibe, comprador gestiona
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'vendedor', 'almacenero', 'comprador']);
    }

    match /almacenes/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'almacenero']);
    }

    match /transferencias/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'almacenero', 'comprador']);
    }

    // === Reingenieria: Red Logistica ===
    match /casillas/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'almacenero']);
    }

    match /colaboradores/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'almacenero']);
    }

    match /envios/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'almacenero', 'comprador']);
    }

    // === Reingenieria: Costos y Finanzas ===
    match /categoriasCostos/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    match /insumos/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'almacenero']);
    }

    match /kitsEmpaque/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'almacenero']);
    }

    match /tarjetasCredito/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    match /ordenesCompra/{docId} {
      // Vendedor/comprador crea OC desde requerimientos, almacenero recibe
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'vendedor', 'almacenero', 'comprador']);
    }

    match /ordenesCompraArchivo/{docId} {
      // Archivo de OC eliminadas (trazabilidad)
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente']);
    }

    // ============================================================
    // INCIDENCIAS DE OC (S54 · Tanda 2)
    // ============================================================
    match /incidenciasOC/{docId} {
      // Mismos permisos que OC: cualquier activo puede leer, los roles
      // operativos pueden crear/actualizar incidencias.
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'vendedor', 'almacenero', 'comprador', 'finanzas']);
    }

    // ============================================================
    // GASTOS (admin, gerente, finanzas, vendedor para GD de entregas)
    // ============================================================
    match /gastos/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas', 'vendedor']);
    }

    // ============================================================
    // FINANZAS / TESORERIA (admin, gerente, finanzas)
    // ============================================================
    match /movimientosTesoreria/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    match /cuentasCaja/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    match /conversionesCambiarias/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    match /aportesCapital/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    match /retirosCapital/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    match /registrosTCTransaccion/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    // ============================================================
    // POOL USD — Rendimiento Cambiario
    // ============================================================
    match /poolUSDMovimientos/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    match /poolUSDSnapshots/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    match /historialRecalculoCTRU/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    match /_errorLog/{docId} {
      allow read: if isAdmin();
      allow create: if isActiveUser();
      allow update, delete: if false;
    }

    match /estadisticas/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    // ============================================================
    // DATOS MAESTROS (todos leen, solo admin escribe)
    // ============================================================
    match /marcas/{docId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    match /categorias/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente']);
    }

    match /tiposProducto/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente']);
    }

    match /canalesVenta/{docId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    match /etiquetas/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente']);
    }

    match /competidores/{docId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    match /transportistas/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'vendedor']);
    }

    match /tiposCambio/{docId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    // ============================================================
    // SISTEMA (notificaciones, auditoria, analytics)
    // ============================================================
    match /notificaciones/{docId} {
      allow read: if isActiveUser();
      // SEC-010: Users can only create notifications for themselves
      allow create: if isActiveUser();
      allow update, delete: if isActiveUser() && resource.data.userId == request.auth.uid;
    }

    match /audit_logs/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow create: if isActiveUser();
      allow update, delete: if isAdmin();
    }

    match /movimientos_transportista/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'vendedor']);
    }

    // ============================================================
    // COLABORACION (presencia, actividad, chat)
    // ============================================================
    match /presencia/{docId} {
      allow read: if isActiveUser();
      // SEC-010: Users can only write their own presence document
      allow write: if isActiveUser() && docId == request.auth.uid;
    }

    match /actividad/{docId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser();
      allow update, delete: if isAdmin();
    }

    match /chat_mensajes/{docId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser();
      allow update, delete: if isAdmin();
    }

    match /chat_meta/{docId} {
      allow read: if isActiveUser();
      allow write: if isActiveUser();
    }

    match /llamadas/{docId} {
      allow read: if isActiveUser();
      allow write: if isActiveUser();
    }

    match /llamadasIntel/{docId} {
      allow read: if isActiveUser();
      allow write: if isActiveUser();
    }

    // ============================================================
    // MERCADO LIBRE (admin y gerente gestionan, todos leen estado)
    // ============================================================
    match /mlConfig/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente']);
    }

    match /mlProductMap/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente']);
    }

    match /mlOrderSync/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente']);
    }

    match /mlQuestions/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente']);
    }

    // ============================================================
    // LINEAS DE NEGOCIO
    // ============================================================
    match /lineasNegocio/{docId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    // ============================================================
    // PAISES DE ORIGEN
    // ============================================================
    match /paisesOrigen/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente']);
    }

    // ============================================================
    // CONFIGURACION DE EMPRESA
    // ============================================================
    match /configuracion/{docId} {
      allow read: if isActiveUser();
      // tipoCambio config es crítico — solo admin puede modificar umbrales
      allow write: if (docId == 'tipoCambio' && hasAnyRole(['admin']))
                   || (docId != 'tipoCambio' && hasAnyRole(['admin', 'gerente']));
    }

    // ============================================================
    // ESCANER E INVENTARIO FISICO
    // SEC-006 FIX: Colecciones que el frontend necesita pero no tenían reglas
    // ============================================================
    match /scanHistory/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'almacenero', 'vendedor']);
    }

    match /conteosInventario/{docId} {
      allow read: if isActiveUser();
      allow write: if hasAnyRole(['admin', 'gerente', 'almacenero']);
    }

    // ============================================================
    // WHATSAPP (Cloud Functions escriben via admin SDK, UI solo lee)
    // ============================================================
    match /whatsapp_sessions/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente']);
      allow write: if false; // Solo Cloud Functions via admin SDK
    }

    match /whatsapp_config/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente']);
      allow write: if false; // Solo Cloud Functions via admin SDK
    }

    // ============================================================
    // ML WEBHOOK LOG (Cloud Functions escriben, admin puede leer para debug)
    // ============================================================
    match /mlWebhookLog/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente']);
      allow write: if false; // Solo Cloud Functions via admin SDK
    }

    // ============================================================
    // CIERRES CONTABLES (solo admin escribe, roles financieros leen)
    // @deprecated chk5.E-RM · reemplazado por revisionesMensuales
    // ============================================================
    match /cierresContables/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if isAdmin();
    }

    // ============================================================
    // chk5.E-RM · REVISIONES MENSUALES (informal · sin bloqueo · audit trail)
    // Reemplaza cierresContables. Mismo perfil de permisos: roles
    // financieros leen, admin/gerente/finanzas pueden marcar revisión.
    // ============================================================
    match /revisionesMensuales/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    // ============================================================
    // chk5.PERF-MATERIALIZACION · ESTADÍSTICAS CONTABLES (snapshots P&L mensuales)
    // Cache derivado pre-calculado de meses cerrados · acelera Contabilidad e
    // Inversionistas (evita recomputar 12-24 estados desde movimientos en cada visita).
    // Los roles que LEEN contabilidad pueden leer y materializar (write best-effort al
    // haber cache miss). admin incluido (principio "admin ve todo").
    // ============================================================
    match /estadisticasContables/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
    }

    // ============================================================
    // chk5.E-INV · SOCIOS / INVERSIONISTAS
    // Catálogo de socios del negocio. Acceso restringido: solo admin
    // y gerente leen/escriben. Los socios individuales (cuando existan
    // como usuarios con permiso VER_INVERSIONISTAS) verán los datos
    // agregados desde el módulo /inversionistas, no escriben directo.
    // ============================================================
    match /socios/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente']);
      allow write: if hasAnyRole(['admin', 'gerente']);
    }

    // ============================================================
    // LOTES DE PAGOS MASIVOS
    // ============================================================
    match /lotePagos/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    // ============================================================
    // CONTADORES SECUENCIALES (numeros de venta, gasto, etc.)
    // ============================================================
    match /contadores/{docId} {
      allow read: if isActiveUser();
      // SEC-006: Only allow increment by 1 to prevent sequence manipulation
      allow create: if hasAnyRole(['admin', 'gerente']);
      allow update: if hasAnyRole(['admin', 'gerente', 'vendedor', 'finanzas'])
        && request.resource.data.current == resource.data.current + 1;
    }

    // ============================================================
    // WHATSAPP MESSAGES (Cloud Functions escriben, admin puede leer)
    // ============================================================
    match /whatsapp_messages/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente']);
      allow write: if false; // Solo Cloud Functions via admin SDK
    }

    // ============================================================
    // DEVOLUCIONES
    // Vendedor y almacenero pueden crear/leer; admin y gerente aprueban/rechazan.
    // La lógica de roles finos se maneja en el servicio — aquí se permite a
    // usuarios activos leer y a roles operativos escribir.
    // ============================================================
    match /devoluciones/{docId} {
      allow read: if isActiveUser();
      allow create: if hasAnyRole(['admin', 'gerente', 'vendedor', 'almacenero']);
      allow update: if hasAnyRole(['admin', 'gerente', 'vendedor', 'almacenero']);
      allow delete: if isAdmin();
    }

    // ============================================================
    // PLANILLA + SUB-PERFILES — Datos privados del user (subcoleccion)
    // chk5.F2-SUB-PERFILES (2026-05-24) · agregados:
    //   - private/datosLaborales (reemplaza /empleados a partir de Fase 2)
    //   - private/datosSocio (reemplaza /socios a partir de Fase 2)
    //   - private/* otros docs legacy
    //
    // Acceso:
    //   - admin · gerente · siempre (gestión RRHH y socios)
    //   - finanzas · datosLaborales (para procesar nómina) · NO datosSocio
    //   - El propio usuario · puede leer sus propios sub-perfiles (NO escribir)
    // ============================================================
    match /users/{userId}/private/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente'])
                  || (docId == 'datosLaborales' && hasRole('finanzas'))
                  || (request.auth != null && request.auth.uid == userId);
      allow write: if hasAnyRole(['admin', 'gerente']);
    }

    // ============================================================
    // PLANILLA — Boletas de pago
    // Admin, gerente y finanzas pueden leer; admin y gerente escriben.
    // ============================================================
    match /boletas/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow create: if hasAnyRole(['admin', 'gerente']);
      allow update: if hasAnyRole(['admin', 'gerente']);
      allow delete: if isAdmin();
    }

    // ============================================================
    // PLANILLA — Adelantos de nómina
    // ============================================================
    match /adelantosNomina/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow create: if hasAnyRole(['admin', 'gerente']);
      allow update: if hasAnyRole(['admin', 'gerente']);
      allow delete: if isAdmin();
    }

    // ============================================================
    // chk5.PERSONAS-v5.4 · F3 · PLANILLA v5.4 (2026-05-26)
    // 5 colecciones nuevas · todas con permisos consistentes:
    //  - read: admin · gerente · finanzas
    //  - write (create/update): admin · gerente
    //  - delete: solo admin (audit trail · soft delete preferido)
    // ============================================================

    /** Historial de variaciones salariales · trazabilidad ajustes/promociones */
    match /historialSalarial/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow create: if hasAnyRole(['admin', 'gerente']);
      allow update: if hasAnyRole(['admin', 'gerente']);
      allow delete: if isAdmin();
    }

    /** Esquemas de incentivo (templates) · 4 tipos canon */
    match /esquemasIncentivo/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow create: if hasAnyRole(['admin', 'gerente']);
      allow update: if hasAnyRole(['admin', 'gerente']);
      allow delete: if isAdmin();
    }

    /** Cálculos mensuales de incentivos · workflow calculado→aprobado→en_boleta */
    match /calculosIncentivo/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow create: if hasAnyRole(['admin', 'gerente']);
      allow update: if hasAnyRole(['admin', 'gerente']);
      allow delete: if isAdmin();
    }

    /** Liquidaciones por baja de empleado · workflow borrador→aprobada→pagada */
    match /liquidacionesEmpleado/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow create: if hasAnyRole(['admin', 'gerente']);
      allow update: if hasAnyRole(['admin', 'gerente']);
      allow delete: if isAdmin();
    }

    /** Gratificaciones jul/dic · Vita Skin NO paga CTS */
    match /gratificaciones/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow create: if hasAnyRole(['admin', 'gerente']);
      allow update: if hasAnyRole(['admin', 'gerente']);
      allow delete: if isAdmin();
    }

    // ============================================================
    // S55 · CUENTA CORRIENTE UNIFICADA
    // ============================================================
    // Doc raíz por entidad (cliente/proveedor/colaborador/empleado).
    // El saldo se actualiza SOLO desde el service vía transacción
    // atómica que también escribe en movimientosCC. La regla previene
    // updates manuales del saldo desde el cliente, pero permite update
    // dentro de transacciones (Firestore evalúa la regla post-batch).
    //
    // Decisiones cerradas:
    //  - Permisos: todos los admins ven todo (por ahora)
    //  - CCs nunca se eliminan (audit trail histórico)
    //  - Movimientos son inmutables (no update, no delete)
    match /cuentasCorrientes/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow create: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow update: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow delete: if false;
    }

    // Movimientos CC = libro contable inmutable. NUNCA se editan ni borran.
    // Solo se crean (atómicamente con update de la CC padre vía transacción).
    match /movimientosCC/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow create: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow update: if false;
      allow delete: if false;
    }

    // ============================================================
    // S58c-PF · ADR-PF-001 · PRODUCTO FINANCIERO UNIFICADO
    // Reemplaza cuentasCaja + tarjetasCredito en F4-F5.
    // Mismo patrón de permisos que cuentasCaja: roles financieros.
    // ============================================================
    match /productosFinancieros/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    // RelacionBancaria — vínculo titular ↔ banco
    match /relacionesBancarias/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow write: if hasAnyRole(['admin', 'gerente', 'finanzas']);
    }

    // Libro mayor unificado. Update permitido SOLO para anulación (preserva
    // audit trail con estado='anulado', no borra). Delete prohibido.
    match /movimientosFinancieros/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow create: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow update: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow delete: if false;
    }

    // ============================================================
    // chk5.D-S1f · Caja Recaudadora (D5 + D12) · 2026-05-15
    // ============================================================

    // Eventos atómicos de Caja Recaudadora (cobros entrantes + servicios
    // descontados). Update permitido SOLO para marcar como liquidado o
    // cancelar (audit trail preservado). Delete prohibido.
    match /eventosServicioRecaudador/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow create: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow update: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow delete: if false;
    }

    // Documentos de liquidación periódica. Update permitido SOLO para
    // anulación (estado='anulada' preserva histórico). Delete prohibido.
    match /liquidacionesRecaudadora/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente', 'finanzas', 'supervisor']);
      allow create: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow update: if hasAnyRole(['admin', 'gerente', 'finanzas']);
      allow delete: if false;
    }

    // ============================================================
    // chk5.F4-USERS (2026-05-25) · INVITACIONES
    // Admin/gerente leen y crean (vía Cloud Function); user normal NO accede.
    // Las CF usan admin SDK (bypassa rules); las rules cubren acceso UI.
    // ============================================================
    match /invitaciones/{docId} {
      allow read: if hasAnyRole(['admin', 'gerente']);
      // Crear/update/delete debe ir por Cloud Function (admin SDK)
      // para validar token JWT, enviar email, audit log. Bloqueamos UI directa.
      allow write: if false;
    }

    // ============================================================
    // chk5.F4-USERS (2026-05-25) · SESIONES ACTIVAS
    // El propio user puede crear/leer/actualizar SUS sesiones.
    // Admin lee todas. Cerrar sesiones forzado va por Cloud Function.
    // ============================================================
    match /sessions/{sessionId} {
      allow read: if request.auth != null && (
        hasAnyRole(['admin', 'gerente']) ||
        (resource != null && resource.data.uid == request.auth.uid)
      );
      // User puede crear su propia sesión (en login) y actualizar lastActive
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.estado == 'activa';
      allow update: if request.auth != null && (
        // El propio user actualiza lastActive o cierra su sesión
        (resource != null && resource.data.uid == request.auth.uid
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'lastActive', 'estado', 'fechaCierre', 'motivoCierre'
         ]))
        // O admin (vía CF generalmente, pero admin puede directo)
        || hasAnyRole(['admin', 'gerente'])
      );
      allow delete: if isAdmin();
    }

    // ============================================================
    // chk5.PERSONAS-v5.6/v5.8 (2026-05-28) · RELACIONES LABORALES
    // Multi-relación + Histórico + Vinculación con Maestros.
    // - Admin: read+write completo (canon admin ve todo 2026-05-24)
    // - Gerente: read (auditoría) + write si es socio
    // - Finanzas: read (para procesar nómina · solo relaciones tipo='empleado')
    // - User dueño: read SOLO de SUS propias relaciones (where userId == uid)
    // - Crear/finalizar/reclasificar: solo admin (cambios sensibles)
    // ============================================================
    match /relacionesLaborales/{relacionId} {
      allow read: if request.auth != null && (
        hasAnyRole(['admin', 'gerente', 'finanzas']) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );

      // Crear · solo admin (los wizards y CF crean docs)
      allow create: if isAdmin()
        && request.resource.data.creadoPor == request.auth.uid
        && request.resource.data.userId is string
        && request.resource.data.tipo in ['empleado', 'honorarios', 'socio', 'externo']
        && request.resource.data.estado in ['vigente', 'pausada', 'prueba', 'finalizada'];

      // Update · admin solamente (transitions de estado · vinculación · ajustes)
      // No se permite cambiar userId ni tipo después de creado (sólo via reclasificación atomic)
      allow update: if isAdmin()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.tipo == resource.data.tipo;

      // Delete · prohibido (audit trail · soft delete via estado=finalizada)
      allow delete: if false;
    }

    // ============================================================
    // chk5.PERSONAS-v5.9 (2026-05-28) · SOLICITUDES DE ACCESO EXTERNO
    // Pre-stage antes de crear UserProfile · viene de /solicitar-acceso público.
    // - Crear: PÚBLICO (no requiere auth) · pero con validaciones server-side
    //   y reCAPTCHA · y Firestore aplica límites de tamaño + campos requeridos
    // - Read: solo admin (canon admin ve todo) y gerente (auditoría)
    // - Update: solo admin · transiciones de estado (pendiente → info_solicitada
    //   → aprobada/rechazada/caducada). Aprobada/rechazada DEBEN ir por CF
    //   para crear User + Relacion + Invitacion atómicamente (acá solo update doc).
    // - Delete: prohibido (audit trail)
    // ============================================================
    match /solicitudesAccesoExterno/{solicitudId} {
      // Crear público con validaciones (anti-spam · campos requeridos)
      allow create: if
        // Campos obligatorios + tipos
        request.resource.data.nombreCompleto is string
        && request.resource.data.nombreCompleto.size() >= 3
        && request.resource.data.nombreCompleto.size() <= 200
        && request.resource.data.email is string
        && request.resource.data.email.matches('.*@.*[.].*')
        && request.resource.data.tipoRelacion in ['proveedor', 'cliente', 'transportista', 'colaborador', 'otro']
        && request.resource.data.motivo is string
        && request.resource.data.motivo.size() >= 20
        && request.resource.data.motivo.size() <= 2000
        // Estado inicial OBLIGATORIO 'pendiente' · no puede saltar a aprobada en create
        && request.resource.data.estado == 'pendiente'
        // Anti-bypass · no aceptar campos que solo admin puede setear
        && !('procesadaPor' in request.resource.data)
        && !('fechaProcesamiento' in request.resource.data)
        && !('uidUsuarioCreado' in request.resource.data);

      allow read: if request.auth != null && hasAnyRole(['admin', 'gerente']);

      allow update: if isAdmin()
        // No se puede cambiar el email original (anti-fraude · evitar que admin se confunda)
        && request.resource.data.email == resource.data.email
        // No se puede cambiar la fecha de creación
        && request.resource.data.fechaCreacion == resource.data.fechaCreacion;

      allow delete: if false;
    }

    // ============================================================
    // SIN REGLA CATCH-ALL
    // Cualquier coleccion no listada arriba sera DENEGADA por defecto.
    // ============================================================
  }
}
