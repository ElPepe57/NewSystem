rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de perfil: el propio usuario puede subir, todos autenticados pueden leer
    match /profile-photos/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024  // Max 2MB
        && request.resource.contentType.matches('image/.*');
    }

    // SEC-005 FIX: Audio de llamadas — solo usuarios autenticados, max 50MB
    match /llamadas-audio/{llamadaId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024  // Max 50MB
        && request.resource.contentType.matches('audio/.*');
    }

    // SEC-005 FIX: Comprobantes — solo admin/finanzas pueden escribir, autenticados leer
    match /comprobantes/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;  // Max 10MB
    }

    // SEC-005 FIX: Denegar todo lo demás explícitamente
    // Si se necesita un nuevo path, agregar una regla específica arriba
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
